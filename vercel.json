{
      "version": 2,
      "buildCommand": "npm install --prefix frontend && npm run build --prefix frontend",
      "outputDirectory": "frontend/dist",
      "functions": {
              "api/index.js": {
                        "maxDuration": 30
              }
      },
      "rewrites": [
              { "source": "/api/(.*)", "destination": "/api/index.js" },
              { "source": "/(.*)", "destination": "/index.html" }
      ]
}
